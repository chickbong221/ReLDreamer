--- a/teemo_sim_probe/configs/thresholds.yaml
+++ b/teemo_sim_probe/configs/thresholds.yaml
@@
 grasp:
   max_angle: 30             # MS-HAB convention for agent.is_grasping
+  # Gripper-link local axis that points OUT of the gripper (approach axis).
+  # Fetch/Panda gripper_link: +Z. Used for ee--interactive orientation-alignment.
+  tcp_approach_axis_local: [0.0, 0.0, 1.0]
@@ profiles.tabletop:
-    tcp_affordance_alignment:    # ee-active_target, |tcp - anchor_world|
-      edges:  [0.01, 0.03, 0.07, 0.15]
-      labels: [on-anchor, very-near, near, off, far]
+    orientation_alignment:       # ee-interactive, angle(rad) TCP vs aff axis
+      edges:  [0.17, 0.52, 1.05, 1.57]     # ~10deg, 30deg, 60deg, 90deg
+      labels: [aligned, near-aligned, oblique, perpendicular, opposed]
@@ profiles.tabletop (change specs):
-    tcp_affordance_alignment_change:  # signed delta distance over K
-      edges:  [-0.05, -0.02, -0.005, 0.005, 0.02, 0.05]
-      labels: [approach-anchor-fast, approach-anchor-medium, approach-anchor-slow,
-               stable-anchor,
-               leave-anchor-slow, leave-anchor-medium, leave-anchor-fast]
+    orientation_alignment_change:     # signed delta angle(rad) over K
+      edges:  [-0.35, -0.12, -0.03, 0.03, 0.12, 0.35]
+      labels: [align-fast, align-medium, align-slow,
+               stable-orientation,
+               misalign-slow, misalign-medium, misalign-fast]
@@ profiles.room_scale:
-    tcp_affordance_alignment:
-      edges:  [0.02, 0.05, 0.12, 0.30]
-      labels: [on-anchor, very-near, near, off, far]
+    orientation_alignment:       # angle is robot-local; same bins as tabletop
+      edges:  [0.17, 0.52, 1.05, 1.57]
+      labels: [aligned, near-aligned, oblique, perpendicular, opposed]
@@ profiles.room_scale (change specs):
-    tcp_affordance_alignment_change:
-      edges:  [-0.15, -0.06, -0.015, 0.015, 0.06, 0.15]
-      labels: [approach-anchor-fast, approach-anchor-medium, approach-anchor-slow,
-               stable-anchor,
-               leave-anchor-slow, leave-anchor-medium, leave-anchor-fast]
+    orientation_alignment_change:     # same as tabletop -- angle is robot-local
+      edges:  [-0.35, -0.12, -0.03, 0.03, 0.12, 0.35]
+      labels: [align-fast, align-medium, align-slow,
+               stable-orientation,
+               misalign-slow, misalign-medium, misalign-fast]
